@model IEnumerable<Banvemaybay.Models.ChuyenBay>
@using Banvemaybay.Models
@{
    ViewData["Title"] = "Gợi Ý Chuyến Bay Dành Cho Bạn";
    var dsSanBay = ViewBag.DanhSachSanBay as List<SanBay> ?? new List<SanBay>();
}

<style>
    .flight-card {
        transition: all 0.3s ease;
        border-left: 5px solid #00bcd4;
    }

        .flight-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            border-left: 5px solid #ff5722;
        }

    .airline-logo {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 20px;
        color: white;
    }

    .bg-vj {
        background-color: #ed1c24;
    }
    /* Vietjet Đỏ */
    .bg-vn {
        background-color: #005a8c;
    }
    /* VNA Xanh dương */
    .bg-qh {
        background-color: #4caf50;
    }
    /* Bamboo Xanh lá */
</style>

<div class="container" style="margin-top: 150px; margin-bottom: 100px;">
    <div class="text-center mb-5">
        <h2 class="fw-bold" style="color: #00bcd4;">ƯU ĐÃI DÀNH RIÊNG CHO BẠN</h2>
        <p class="text-muted">Lên kế hoạch vi vu ngay với những chuyến bay sắp khởi hành có mức giá tốt nhất.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10">
            @if (!Model.Any())
            {
                <div class="alert alert-warning text-center py-4 rounded-3 shadow-sm">
                    <i class="fas fa-plane-slash fs-1 text-muted mb-3"></i>
                    <h5 class="fw-bold">Hiện tại chưa có chuyến bay nào sắp khởi hành!</h5>
                    <p class="mb-0">Vui lòng quay lại sau hoặc sử dụng công cụ tìm kiếm.</p>
                </div>
            }
            else
            {
                foreach (var item in Model)
                {
                    var tenDi = dsSanBay.FirstOrDefault(s => s.Id == item.DiemDiId)?.TenThanhPho ?? "N/A";
                    var tenDen = dsSanBay.FirstOrDefault(s => s.Id == item.DiemDenId)?.TenThanhPho ?? "N/A";

                    // Gán màu logo tượng trưng theo hãng
                    string logoClass = "bg-secondary";
                    string kyHieu = item.HangHangKhong.Substring(0, 1).ToUpper();
                    if (item.HangHangKhong.Contains("Vietjet")) { logoClass = "bg-vj"; kyHieu = "VJ"; }
                    else if (item.HangHangKhong.Contains("Vietnam")) { logoClass = "bg-vn"; kyHieu = "VN"; }
                    else if (item.HangHangKhong.Contains("Bamboo")) { logoClass = "bg-qh"; kyHieu = "QH"; }

                    <div class="card mb-4 flight-card shadow-sm border-0 rounded-3">
                        <div class="card-body p-4">
                            <div class="row align-items-center text-center text-md-start">
                                <div class="col-md-3 d-flex flex-column align-items-center align-items-md-start mb-3 mb-md-0">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="airline-logo @logoClass me-3 shadow-sm">@kyHieu</div>
                                        <div>
                                            <h6 class="fw-bold mb-0 text-dark">@item.HangHangKhong</h6>
                                            <small class="text-muted">Mã: @item.MaChuyenBay</small>
                                        </div>
                                    </div>
                                    <span class="badge bg-light text-dark border">Bay thẳng</span>
                                </div>

                                <div class="col-md-6 mb-3 mb-md-0 px-4">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="text-center">
                                            <h4 class="fw-bold text-primary mb-0">@item.ThoiGianDi.ToString("HH:mm")</h4>
                                            <div class="fs-6 fw-bold">@tenDi</div>
                                            <small class="text-muted">@item.ThoiGianDi.ToString("dd/MM/yyyy")</small>
                                        </div>

                                        <div class="text-center flex-grow-1 px-3">
                                            <div class="text-muted small mb-1">Thời gian bay</div>
                                            <div class="position-relative">
                                                <hr class="border-info border-2 opacity-50 my-0">
                                                <i class="fas fa-plane text-info position-absolute top-50 start-50 translate-middle bg-white px-2"></i>
                                            </div>
                                        </div>

                                        <div class="text-center">
                                            <h4 class="fw-bold text-success mb-0">@item.ThoiGianDen.ToString("HH:mm")</h4>
                                            <div class="fs-6 fw-bold">@tenDen</div>
                                            <small class="text-muted">@item.ThoiGianDen.ToString("dd/MM/yyyy")</small>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-3 text-center text-md-end border-start-md">
                                    @if (item.GiaKhuyenMai > 0 && item.GiaKhuyenMai < item.GiaVe)
                                    {
                                        <div class="text-muted text-decoration-line-through small">@item.GiaVe.ToString("N0") VNĐ</div>
                                        <h4 class="fw-bold text-danger mb-2">@item.GiaKhuyenMai.ToString("N0") <span class="fs-6 text-muted">VNĐ</span></h4>
                                        <div class="badge bg-danger mb-3">Đang khuyến mãi</div>
                                    }
                                    else
                                    {
                                        <h4 class="fw-bold text-danger mb-3 mt-2">@item.GiaVe.ToString("N0") <span class="fs-6 text-muted">VNĐ</span></h4>
                                    }

                                    <a href="/Ve/ChonGhe?chuyenBayId=@item.Id" class="btn btn-warning w-100 fw-bold shadow-sm" style="border-radius: 8px;">CHỌN VÉ NGAY</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>