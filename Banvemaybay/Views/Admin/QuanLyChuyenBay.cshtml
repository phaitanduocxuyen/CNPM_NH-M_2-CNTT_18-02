@model IEnumerable<Banvemaybay.Models.ChuyenBay>
@using Banvemaybay.Models
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Quản Lý Chuyến Bay";
    var dsSanBay = ViewBag.DanhSachSanBay as List<SanBay> ?? new List<SanBay>();
}

<div class="d-flex justify-content-end mb-3">
    <a href="/Admin/ThemChuyenBay" class="btn btn-success fw-bold shadow-sm"><i class="fas fa-plus"></i> Thêm Chuyến Bay Mới</a>
</div>

<div class="card shadow-sm border-0 p-0" style="border-radius: 10px;">
    <div class="table-responsive">
        <table class="table table-hover text-center align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="py-3">Mã CB</th>
                    <th>Hãng bay</th>
                    <th>Nơi Đi</th>
                    <th>Nơi Đến</th>
                    <th>Giờ Đi</th>
                    <th>Giá KM (VNĐ)</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var tenDi = dsSanBay.FirstOrDefault(s => s.Id == item.DiemDiId)?.TenThanhPho ?? item.DiemDiId.ToString();
                        var tenDen = dsSanBay.FirstOrDefault(s => s.Id == item.DiemDenId)?.TenThanhPho ?? item.DiemDenId.ToString();

                        <tr>
                            <td class="fw-bold">@item.MaChuyenBay</td>
                            <td><span class="badge bg-info text-dark">@item.HangHangKhong</span></td>
                            <td class="fw-bold text-primary">@tenDi</td>
                            <td class="fw-bold text-success">@tenDen</td>
                            <td>@item.ThoiGianDi.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-danger fw-bold">@item.GiaKhuyenMai.ToString("N0")</td>
                            <td>
                                <a href="/Admin/SuaChuyenBay?id=@item.Id" class="btn btn-warning btn-sm fw-bold"><i class="fas fa-edit"></i> Sửa</a>
                                <a href="/Admin/XoaChuyenBay?id=@item.Id" class="btn btn-danger btn-sm fw-bold" onclick="return confirm('Xóa chuyến bay @item.MaChuyenBay?');"><i class="fas fa-trash-alt"></i> Xóa</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center py-5 text-muted">Chưa có chuyến bay nào trong hệ thống!</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>