@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Cổng Quản Trị Hệ Thống</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body class="bg-dark">
    <div class="container mt-5 pt-5">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card shadow-lg border-0 rounded-lg mt-5" style="background-color: #2c3e50;">
                    <div class="card-header text-center py-4" style="border-bottom: 2px solid #f1c40f;">
                        <h3 class="fw-bold mb-0" style="color: #f1c40f;"><i class="fas fa-user-shield"></i> CỔNG ADMIN</h3>
                    </div>
                    <div class="card-body p-4 bg-light">
                        @if (ViewBag.Loi != null)
                        {
                            <div class="alert alert-danger text-center fw-bold">@ViewBag.Loi</div>
                        }

                        <form action="/Admin/Login" method="post">
                            <div class="form-floating mb-4 mt-2">
                                <input type="password" class="form-control fw-bold text-center text-danger" id="matKhauAdmin" name="matKhauAdmin" placeholder="Nhập mã bảo mật" required style="font-size: 24px; letter-spacing: 5px;" />
                                <label for="matKhauAdmin">Nhập mã truy cập</label>
                            </div>
                            <button class="btn w-100 fw-bold fs-5 py-2 text-dark" style="background-color: #f1c40f;" type="submit">XÁC NHẬN <i class="fas fa-sign-in-alt"></i></button>
                        </form>
                    </div>
                    <div class="card-footer text-center py-3" style="background-color: #2c3e50;">
                        <a href="/" class="text-decoration-none" style="color: #bdc3c7;"><i class="fas fa-arrow-left"></i> Trở về Trang Khách</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>