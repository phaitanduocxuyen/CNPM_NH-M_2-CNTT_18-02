@model IEnumerable<Banvemaybay.Models.Ve>
@using Banvemaybay.Models
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Quản Lý Vé Máy Bay";
    var dsChuyenBay = ViewBag.DanhSachChuyenBay as List<ChuyenBay> ?? new List<ChuyenBay>();
}

<div class="card shadow-sm border-0 rounded" style="border-radius: 10px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover text-center align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="py-3">Mã Vé (ID)</th>
                        <th>Mã Chuyến Bay</th>
                        <th>Tên Khách Hàng</th>
                        <th>Số Điện Thoại</th>
                        <th>Ghế Đã Chọn</th>
                        <th>Ngày Đặt Vé</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var maCB = dsChuyenBay.FirstOrDefault(c => c.Id == item.ChuyenBayId)?.MaChuyenBay ?? item.ChuyenBayId.ToString();
                            var ngayDatStr = item.NgayDat.ToString("dd/MM/yyyy HH:mm");

                            <tr>
                                <td class="fw-bold text-danger">#@item.Id</td>
                                <td class="fw-bold text-dark">@maCB</td>
                                <td>@item.HoTen</td>
                                <td>@item.SoDienThoai</td>
                                <td><span class="badge bg-success px-3 py-2 fs-6">@item.GheDaChon</span></td>
                                <td>@ngayDatStr</td>
                                <td>
                                    <button class="btn btn-primary btn-sm rounded" onclick="alert('CHI TIẾT VÉ:\n- Khách hàng: @item.HoTen\n- SĐT: @item.SoDienThoai\n- Mã chuyến bay: @maCB\n- Ghế ngồi: @item.GheDaChon\n- Đặt lúc: @ngayDatStr');">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <a href="/Admin/XoaVe?id=@item.Id" class="btn btn-danger btn-sm rounded" onclick="return confirm('Xóa vé #@item.Id của khách @item.HoTen? Hành động này sẽ giải phóng ghế!');">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center py-5 text-muted fs-5">Chưa có khách hàng nào đặt vé.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>