@{
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="container" style="margin-top: 150px; margin-bottom: 100px;">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <span class="badge bg-info mb-2">Cẩm Nang Du Lịch</span>
            <h1 class="fw-bold text-dark mb-3">Đang cập nhật nội dung chi tiết...</h1>
            <p class="text-muted"><i class="far fa-calendar-alt"></i> Ngày đăng: @DateTime.Now.ToString("dd/MM/yyyy") | <i class="far fa-user"></i> Tác giả: Admin</p>

            <img src="https://picsum.photos/800/400?random=5" class="img-fluid rounded-4 shadow mb-4" alt="Hình minh họa">

            <p class="text-secondary text-start" style="line-height: 1.8; font-size: 16px;">
                Cảm ơn bạn đã quan tâm đến bài viết của Travelz! Nội dung chi tiết của bài viết này đang trong quá trình biên tập và sẽ sớm được cập nhật trên hệ thống.
                <br /><br />
                Trong lúc chờ đợi, bạn có thể quay lại trang trước để đọc các bài viết khác hoặc trải nghiệm tính năng đặt vé máy bay siêu tốc của chúng tôi!
            </p>

            <a href="/BaiViet/Index" class="btn btn-outline-primary mt-4 fw-bold"><i class="fas fa-arrow-left me-2"></i> Quay lại danh sách</a>
        </div>
    </div>
</div>