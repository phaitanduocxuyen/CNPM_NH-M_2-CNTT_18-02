@{
    ViewData["Title"] = "Nhập Thông Tin & Thanh Toán";
}
<div class="container" style="margin-top: 150px; margin-bottom: 100px;">
    <h2 class="text-info fw-bold mb-4 text-center">Hoàn Tất Đặt Vé</h2>

    <div class="row">
        <div class="col-md-7 mb-4">
            <div class="card shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-header bg-info text-white py-3" style="border-radius: 12px 12px 0 0;">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-user-edit"></i> Thông Tin Hành Khách</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-controller="Ve" asp-action="HoanTatDatVe" method="post">
                        <input type="hidden" name="chuyenBayId" value="@ViewBag.ChuyenBayId" />
                        <input type="hidden" name="gheDaChon" value="@ViewBag.GheDaChon" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ và tên hành khách</label>
                            <input type="text" name="hoTen" class="form-control form-control-lg bg-light" value="@ViewBag.TenKhachHang" placeholder="VÍ DỤ: NGUYEN VAN A" required style="text-transform: uppercase;" />
                            <small class="text-muted">Nhập tên in hoa không dấu, khớp với giấy tờ tùy thân.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Số điện thoại liên hệ</label>
                            <input type="tel" name="soDienThoai" class="form-control form-control-lg bg-light" value="@ViewBag.SoDienThoaiKhach" placeholder="VD: 0912345678" required />
                            <small class="text-muted">Mã vé và thông tin chuyến bay sẽ được gửi qua số này.</small>
                        </div>

                        <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold text-dark shadow-sm">
                            <i class="fas fa-check-circle"></i> XÁC NHẬN & ĐẶT VÉ
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0" style="border-radius: 12px; background-color: #f8f9fa;">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark mb-4"><i class="fas fa-receipt text-info"></i> Tóm Tắt Chuyến Bay</h5>

                    @if (ViewBag.ChuyenBay != null)
                    {
                        var cb = ViewBag.ChuyenBay as Banvemaybay.Models.ChuyenBay;

                        <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                            <div class="text-center">
                                <h4 class="fw-bold text-primary mb-0">@ViewBag.SanBayDi</h4>
                                <small class="text-muted">@cb?.ThoiGianDi.ToString("HH:mm")</small>
                            </div>
                            <div class="text-center text-muted">
                                <i class="fas fa-plane text-info" style="font-size: 20px;"></i>
                                <div class="small mt-1">@cb?.HangHangKhong</div>
                            </div>
                            <div class="text-center">
                                <h4 class="fw-bold text-success mb-0">@ViewBag.SanBayDen</h4>
                                <small class="text-muted">@cb?.ThoiGianDen.ToString("HH:mm")</small>
                            </div>
                        </div>

                        <ul class="list-group list-group-flush bg-transparent">
                            <li class="list-group-item bg-transparent d-flex justify-content-between px-0">
                                <span class="text-muted">Ngày khởi hành:</span>
                                <strong>@cb?.ThoiGianDi.ToString("dd/MM/yyyy")</strong>
                            </li>
                            <li class="list-group-item bg-transparent d-flex justify-content-between px-0">
                                <span class="text-muted">Ghế đã chọn:</span>
                                <strong><span class="badge bg-dark fs-6">@ViewBag.GheDaChon</span></strong>
                            </li>
                            
                            @if (ViewBag.SoGheVip > 0)
                            {
                                <li class="list-group-item bg-transparent d-flex justify-content-between px-0 text-warning">
                                    <span><i class="fas fa-star"></i> Thương gia (@ViewBag.SoGheVip ghế):</span>
                                    <strong>@ViewBag.GiaVeVip.ToString("N0") VNĐ</strong>
                                </li>
                            }
                            @if (ViewBag.SoGheThuong > 0)
                            {
                                <li class="list-group-item bg-transparent d-flex justify-content-between px-0 text-info">
                                    <span>Phổ thông (@ViewBag.SoGheThuong ghế):</span>
                                    <strong>@ViewBag.GiaVeThuong.ToString("N0") VNĐ</strong>
                                </li>
                            }
                        </ul>

                        <div class="mt-4 p-3 rounded shadow-sm" style="background-color: #fff9c4; border: 2px dashed #fbc02d;">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-dark fs-5">TỔNG TIỀN:</span>
                                <span class="fw-bold text-danger fs-3">@ViewBag.TongTien.ToString("N0") VNĐ</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger">Lỗi: Không tải được thông tin chuyến bay!</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>